# ===== Server =====
PORT=3000
# Long random string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_me_with_long_random_string
# Public URL of your Render deployment (no trailing slash). Used for Slack links.
PUBLIC_URL=https://your-app.onrender.com

# ===== Slack =====
# Bot User OAuth Token from https://api.slack.com/apps  -> OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-...
# Channel ID where new request notifications are posted (e.g. C0123456789).
# You said you'd fill this in later -- leave it blank to skip Slack posts.
SLACK_NOTIFY_CHANNEL=

# ===== Google =====
# Service account JSON key from Google Cloud Console.
# Paste the entire JSON (single line, escaped) OR set GOOGLE_APPLICATION_CREDENTIALS to a file path.
# On Render, easiest is to paste the whole JSON in GOOGLE_SERVICE_ACCOUNT_JSON.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Spreadsheet ID (the part between /d/ and /edit in the Sheet URL)
GOOGLE_SHEET_ID=
# Tab name within the sheet (default: Requests)
GOOGLE_SHEET_TAB=Requests
# Google Drive folder ID where signature PNGs are uploaded.
# Get it from the URL after /folders/ -- must be shared with the service account.
GOOGLE_DRIVE_FOLDER_ID=

# ===== Monday.com =====
# API token from monday.com -> profile menu -> Developers -> My Access Tokens
MONDAY_API_TOKEN=
# Board ID -- visible in the board URL: /boards/1234567890
MONDAY_BOARD_ID=
# Column IDs from the board (see README for how to find these via the API)
MONDAY_COL_DATE=date
MONDAY_COL_BRANCH=branch
MONDAY_COL_STATUS=status
MONDAY_COL_TICKET=ticket
